{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WebCli",
  "mainBinaryName": "webcli-app",
  "version": "0.1.2",
  "identifier": "cc.isaaclin.webcli",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WebCLI",
        "width": 1100,
        "height": 760
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "binaries/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
